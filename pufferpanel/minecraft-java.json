{
  "type": "minecraft-itzg",
  "display": "Minecraft Server (Java Host)",
  "icon": "minecraft-java",
  "data": {
    "eula": {
      "type": "boolean",
      "value": false,
      "display": "Accept EULA",
      "desc": "You must agree to the Minecraft EULA to run the server",
      "required": true,
      "userEdit": true
    },
    "modlauncher": {
      "type": "string",
      "value": "paper",
      "display": "Server Type / Mod Launcher",
      "desc": "Select the server distribution or mod launcher to install",
      "required": true,
      "userEdit": true,
      "options": [
        {
          "value": "paper",
          "display": "PaperMC (Recommended - Default)"
        },
        {
          "value": "purpur",
          "display": "PurpurMC (High Performance)"
        },
        {
          "value": "",
          "display": "Vanilla (Official)"
        },
        {
          "value": "fabric",
          "display": "Fabric"
        },
        {
          "value": "forge",
          "display": "Forge"
        },
        {
          "value": "neoforge",
          "display": "NeoForge"
        }
      ]
    },
    "version": {
      "type": "string",
      "value": "latest",
      "display": "Minecraft Version",
      "desc": "Version of Minecraft you wish to install. E.g., `latest` or `1.20.4`",
      "required": true,
      "userEdit": true
    },
    "paperbuild": {
      "type": "string",
      "value": "latest",
      "display": "Paper Build",
      "desc": "Specific build of Paper to install (use `latest` or build number)",
      "required": false,
      "userEdit": true
    },
    "forgebuild": {
      "type": "string",
      "value": "latest",
      "display": "Forge Version",
      "desc": "Specific version of Forge (use `latest` or e.g., `1.20.4-49.0.3`)",
      "required": false,
      "userEdit": true
    },
    "neobuild": {
      "type": "string",
      "value": "latest",
      "display": "NeoForge Version",
      "desc": "Specific version of NeoForge (use `latest` or e.g., `20.4.80`)",
      "required": false,
      "userEdit": true
    },
    "javaversion": {
      "type": "string",
      "value": "21",
      "display": "Java Version",
      "desc": "Java version to use (e.g., 17 for 1.18-1.20.4, 21 for 1.20.5+)",
      "required": true,
      "userEdit": true
    },
    "memory": {
      "type": "integer",
      "value": 2048,
      "display": "Memory Allocation (MB)",
      "desc": "RAM allocated to the server (e.g., 2048 for 2GB, 4096 for 4GB)",
      "required": true,
      "userEdit": false
    },
    "ip": {
      "type": "string",
      "value": "0.0.0.0",
      "display": "Bind IP",
      "desc": "IP address to bind the server to",
      "required": true,
      "userEdit": false
    },
    "port": {
      "type": "integer",
      "value": 25565,
      "display": "Server Port",
      "desc": "The port the Minecraft server will listen on",
      "required": true,
      "userEdit": false
    },
    "motd": {
      "type": "string",
      "value": "A Minecraft Server hosted on PufferPanel",
      "display": "MOTD",
      "desc": "Message of the Day displayed in the server list",
      "required": true,
      "userEdit": true
    },
    "jvmArgsPreset": {
      "type": "option",
      "value": "-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch -XX:G1NewSizePercent=30 -XX:G1MaxNewSizePercent=40 -XX:G1HeapRegionSize=8m -XX:G1ReservePercent=20 -XX:G1HeapWastePercent=5 -XX:G1MixedGCCountTarget=4 -XX:InitiatingHeapOccupancyPercent=15 -XX:G1MixedGCLiveThresholdPercent=90 -XX:G1RSetUpdatingPauseTimePercent=5 -XX:SurvivorRatio=32 -XX:+PerfDisableSharedMem -XX:MaxTenuringThreshold=1",
      "display": "JVM Flags Preset",
      "desc": "Select optimization flags for Java Garbage Collection",
      "required": true,
      "userEdit": true,
      "options": [
        {
          "value": "-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch -XX:G1NewSizePercent=30 -XX:G1MaxNewSizePercent=40 -XX:G1HeapRegionSize=8m -XX:G1ReservePercent=20 -XX:G1HeapWastePercent=5 -XX:G1MixedGCCountTarget=4 -XX:InitiatingHeapOccupancyPercent=15 -XX:G1MixedGCLiveThresholdPercent=90 -XX:G1RSetUpdatingPauseTimePercent=5 -XX:SurvivorRatio=32 -XX:+PerfDisableSharedMem -XX:MaxTenuringThreshold=1",
          "display": "Aikar's Flags (G1GC - Recommended for most servers)"
        },
        {
          "value": "--add-modules=jdk.incubator.vector -XX:+UnlockExperimentalVMOptions -XX:+UnlockDiagnosticVMOptions -XX:+AlwaysPreTouch -XX:+DisableExplicitGC -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:G1NewSizePercent=28 -XX:G1MaxNewSizePercent=50 -XX:G1HeapRegionSize=16M -XX:InitiatingHeapOccupancyPercent=20",
          "display": "MeowIce G1GC Flags (Optimized for modern Java / GraalVM)"
        },
        {
          "value": "--add-modules=jdk.incubator.vector -XX:+UnlockExperimentalVMOptions -XX:+UnlockDiagnosticVMOptions -XX:+AlwaysPreTouch -XX:+DisableExplicitGC -XX:+UseZGC -XX:-ZProactive -XX:+UseNUMA",
          "display": "MeowIce ZGC Flags (Recommended only for 32GB+ RAM & 10+ CPU cores)"
        },
        {
          "value": "custom",
          "display": "Custom (Use custom JVM args field below)"
        }
      ]
    },
    "customJvmArgs": {
      "type": "string",
      "value": "",
      "display": "Custom JVM Arguments",
      "desc": "Enter custom JVM arguments if you selected Custom above",
      "required": false,
      "userEdit": true
    },
    "resolvedForgeVersion": {
      "type": "string",
      "value": "",
      "display": "Resolved Forge Version",
      "required": true,
      "userEdit": true,
      "internal": true
    },
    "resolvedNeoForgeVersion": {
      "type": "string",
      "value": "",
      "display": "Resolved NeoForge Version",
      "required": true,
      "userEdit": true,
      "internal": true
    }
  },
  "groups": [
    {
      "display": "General",
      "description": "General settings for the Minecraft server",
      "variables": [
        "eula",
        "modlauncher",
        "version",
        "javaversion",
        "memory",
        "ip",
        "port",
        "motd",
        "jvmArgsPreset"
      ],
      "order": 1
    },
    {
      "if": "jvmArgsPreset == 'custom'",
      "display": "Custom JVM Args",
      "description": "Specify custom Java arguments",
      "variables": [
        "customJvmArgs"
      ],
      "order": 2
    },
    {
      "if": "modlauncher == 'forge'",
      "display": "Forge Settings",
      "description": "Settings specific to MinecraftForge",
      "variables": [
        "forgebuild"
      ],
      "order": 3
    },
    {
      "if": "modlauncher == 'neoforge'",
      "display": "NeoForge Settings",
      "description": "Settings specific to NeoForge",
      "variables": [
        "neobuild"
      ],
      "order": 4
    },
    {
      "if": "modlauncher == 'paper'",
      "display": "Paper Settings",
      "description": "Settings specific to PaperMC",
      "variables": [
        "paperbuild"
      ],
      "order": 5
    }
  ],
  "install": [
    {
      "if": "javaversion != '' && env == 'host'",
      "type": "javadl",
      "version": "${javaversion}"
    },
    {
      "if": "modlauncher == ''",
      "type": "mojangdl",
      "version": "${version}",
      "target": "server.jar"
    },
    {
      "if": "modlauncher == 'paper'",
      "type": "paperdl",
      "build": "${paperbuild}",
      "minecraftVersion": "${version}",
      "target": "server.jar"
    },
    {
      "if": "modlauncher == 'purpur'",
      "type": "download",
      "files": [
        "https://api.purpurmc.org/v2/purpur/${version}/latest/download"
      ]
    },
    {
      "if": "modlauncher == 'purpur'",
      "type": "move",
      "source": "download",
      "target": "server.jar"
    },
    {
      "if": "modlauncher == 'fabric'",
      "type": "fabricdl"
    },
    {
      "if": "modlauncher == 'fabric' && env == 'host'",
      "type": "command",
      "commands": [
        "java${javaversion} -jar fabric-installer.jar server -mcversion ${version} -downloadMinecraft -noprofile -loader latest"
      ]
    },
    {
      "if": "modlauncher == 'fabric' && env != 'host'",
      "type": "command",
      "commands": [
        "java -jar fabric-installer.jar server -mcversion ${version} -downloadMinecraft -noprofile -loader latest"
      ]
    },
    {
      "if": "modlauncher == 'fabric'",
      "type": "mojangdl",
      "version": "${version}",
      "target": "server.jar"
    },
    {
      "if": "modlauncher == 'forge'",
      "type": "forgedl",
      "target": "installer.jar",
      "version": "${forgebuild}",
      "minecraftVersion": "${version}",
      "outputVariable": "resolvedForgeVersion"
    },
    {
      "if": "modlauncher == 'forge' && env == 'host'",
      "type": "command",
      "commands": [
        "java${javaversion} -jar installer.jar --installServer"
      ]
    },
    {
      "if": "modlauncher == 'forge' && env != 'host'",
      "type": "command",
      "commands": [
        "java -jar installer.jar --installServer"
      ]
    },
    {
      "if": "modlauncher == 'forge' && file_exists('forge-' + resolvedForgeVersion + '-shim.jar')",
      "type": "move",
      "source": "forge-${resolvedForgeVersion}-shim.jar",
      "target": "server.jar"
    },
    {
      "if": "modlauncher == 'forge' && file_exists('forge-' + resolvedForgeVersion + '.jar')",
      "type": "move",
      "source": "forge-${resolvedForgeVersion}.jar",
      "target": "server.jar"
    },
    {
      "if": "modlauncher == 'neoforge'",
      "type": "neoforgedl",
      "target": "installer.jar",
      "version": "${neobuild}",
      "minecraftVersion": "${version}",
      "outputVariable": "resolvedNeoForgeVersion"
    },
    {
      "if": "modlauncher == 'neoforge' && env == 'host'",
      "type": "command",
      "commands": [
        "java${javaversion} -jar installer.jar --installServer"
      ]
    },
    {
      "if": "modlauncher == 'neoforge' && env != 'host'",
      "type": "command",
      "commands": [
        "java -jar installer.jar --installServer"
      ]
    },
    {
      "if": "!file_exists(\"server.properties\")",
      "type": "writefile",
      "text": "server-ip=${ip}\nserver-port=${port}\nmotd=${motd}\n",
      "target": "server.properties"
    },
    {
      "type": "writefile",
      "text": "eula=${eula}",
      "target": "eula.txt"
    }
  ],
  "run": {
    "command": [
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java${javaversion} -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS -jar fabric-server-launch.jar nogui'",
        "if": "env == 'host' && file_exists('fabric-server-launch.jar')"
      },
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS -jar fabric-server-launch.jar nogui'",
        "if": "env != 'host' && file_exists('fabric-server-launch.jar')"
      },
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java${javaversion} -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS -jar server.jar nogui'",
        "if": "env == 'host' && file_exists('server.jar')"
      },
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS -jar server.jar nogui'",
        "if": "env != 'host' && file_exists('server.jar')"
      },
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java${javaversion} -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS @libraries/net/minecraftforge/forge/${resolvedForgeVersion}/unix_args.txt nogui'",
        "if": "env == 'host' && modlauncher == 'forge' && file_exists('libraries/net/minecraftforge/forge/' + resolvedForgeVersion + '/unix_args.txt')"
      },
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java${javaversion} -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS @libraries/net/neoforged/neoforge/${resolvedNeoForgeVersion}/unix_args.txt nogui'",
        "if": "env == 'host' && modlauncher == 'neoforge' && file_exists('libraries/net/neoforged/neoforge/' + resolvedNeoForgeVersion+ '/unix_args.txt')"
      },
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS @libraries/net/minecraftforge/forge/${resolvedForgeVersion}/unix_args.txt nogui'",
        "if": "env != 'host' && modlauncher == 'forge' && file_exists('libraries/net/minecraftforge/forge/' + resolvedForgeVersion+ '/unix_args.txt')"
      },
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS @libraries/net/neoforged/neoforge/${resolvedNeoForgeVersion}/unix_args.txt nogui'",
        "if": "env != 'host' && modlauncher == 'neoforge' && file_exists('libraries/net/neoforged/neoforge/' + resolvedNeoForgeVersion+ '/unix_args.txt')"
      },
      {
        "command": "sh -c 'FLAGS=\"${jvmArgsPreset}\"; if [ \"$FLAGS\" = \"custom\" ]; then FLAGS=\"${customJvmArgs}\"; fi; exec java -Xmx${memory}M -Dterminal.jline=false -Dterminal.ansi=true -Dlog4j2.formatMsgNoLookups=true $FLAGS -jar server.jar nogui'"
      }
    ],
    "pre": [
      {
        "if": "modlauncher == 'forge'",
        "type": "resolveforgeversion",
        "minecraftVersion": "${version}",
        "version": "${forgebuild}",
        "outputVariable": "resolvedForgeVersion"
      },
      {
        "if": "modlauncher == 'neoforge'",
        "type": "resolveneoforgeversion",
        "minecraftVersion": "${version}",
        "version": "${neobuild}",
        "outputVariable": "resolvedNeoForgeVersion"
      }
    ],
    "stop": "stop",
    "stdin": {
      "type": "stdin"
    },
    "autostart": false,
    "autorecover": false,
    "autorestart": false
  },
  "environment": {
    "type": "host"
  },
  "supportedEnvironments": [
    {
      "type": "host"
    },
    {
      "type": "docker",
      "image": "eclipse-temurin:${javaversion}",
      "portBindings": [
        "0.0.0.0:${port}:${port}/tcp"
      ]
    }
  ],
  "requirements": {},
  "stats": {
    "type": "jcmd"
  },
  "query": {
    "type": "minecraft"
  }
}
