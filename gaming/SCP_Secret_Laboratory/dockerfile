# ============================================================
# SCP: Secret Laboratory — Dedicated Server
# Base: Ubuntu 22.04 (jammy)
# Installed via SteamCMD; root is never used at runtime
# ============================================================

# ---- Stage 1: Download / install SteamCMD ----
FROM ubuntu:22.04 AS steamcmd

# Environment variables
ENV DEBIAN_FRONTEND=noninteractive \
    STEAMCMD_DIR=/opt/steamcmd \
    # SCP:SL Steam App ID (dedicated server)
    SCPSL_APPID=996560

# System dependencies + lib32 support (SteamCMD requires 32-bit libs)
RUN dpkg --add-architecture i386 && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    lib32gcc-s1 \
    libstdc++6:i386 \
    libgcc-s1:i386 \
    && rm -rf /var/lib/apt/lists/*

# Install SteamCMD
RUN mkdir -p "${STEAMCMD_DIR}" && \
    curl -fsSL "https://steamcdn-a.akamaihd.net/client/installer/steamcmd_linux.tar.gz" \
    | tar -xz -C "${STEAMCMD_DIR}"

# ---- Stage 2: Runtime image ----
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive \
    # User / group
    SCP_USER=scp \
    SCP_UID=1500 \
    SCP_GID=1500 \
    # Directories
    STEAMCMD_DIR=/opt/steamcmd \
    SERVER_DIR=/opt/scpsl/server \
    CONFIG_DIR=/home/scp/SCP_Secret_Laboratory \
    LOGS_DIR=/home/scp/logs \
    # SteamCMD home directory (download cache)
    STEAM_DIR=/home/scp/.steam \
    # SCP:SL App ID
    SCPSL_APPID=996560 \
    # Headless / no display
    DISPLAY=""

# Runtime dependencies
RUN dpkg --add-architecture i386 && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends \
    ca-certificates \
    lib32gcc-s1 \
    libstdc++6 \
    libstdc++6:i386 \
    libgcc-s1:i386 \
    # screen: keeps the server process running in the background
    screen \
    && rm -rf /var/lib/apt/lists/*

# Copy SteamCMD from the build stage
COPY --from=steamcmd "${STEAMCMD_DIR}" "${STEAMCMD_DIR}"

# Create an unprivileged user
# - NOT in the root group
# - shell is /bin/bash but no sudo/doas available
# - read/write access limited to its own server directory only
RUN groupadd --gid "${SCP_GID}" "${SCP_USER}" && \
    useradd  --uid "${SCP_UID}" \
    --gid "${SCP_GID}" \
    --home-dir "/home/${SCP_USER}" \
    --create-home \
    --shell /bin/bash \
    --no-log-init \
    "${SCP_USER}"

# Create directories and set ownership
# Owned exclusively by the scp user; even root cannot write (chmod 700)
RUN mkdir -p \
    "${SERVER_DIR}" \
    "${CONFIG_DIR}" \
    "${CONFIG_DIR}/config" \
    "${CONFIG_DIR}/SCPSL_Data/Managed/Plugins" \
    "${LOGS_DIR}" \
    "${STEAM_DIR}" \
    "${STEAMCMD_DIR}" && \
    chown -R "${SCP_UID}:${SCP_GID}" \
    "${SERVER_DIR}" \
    "/home/${SCP_USER}" \
    "${STEAMCMD_DIR}" && \
    # Owner can read/write; group and others have no access at all
    chmod -R 700 \
    "${SERVER_DIR}" \
    "/home/${SCP_USER}" && \
    # SteamCMD must be executable, but only by its owner
    chmod 700 "${STEAMCMD_DIR}/steamcmd.sh"

# Root is no longer needed — everything from here runs as the scp user
USER ${SCP_USER}

WORKDIR "/home/${SCP_USER}"

# Download SCP:SL dedicated server files via SteamCMD
# +quit: exit immediately after installation completes
RUN "${STEAMCMD_DIR}/steamcmd.sh" \
    +force_install_dir "${SERVER_DIR}" \
    +login anonymous \
    +app_update "${SCPSL_APPID}" validate \
    +quit

# ---- Entrypoint ----
# Launch the server directly
# Uses the Linux dedicated server binary instead of LocalAdmin.exe
ENTRYPOINT ["/opt/scpsl/server/LocalAdmin"]

# 7777/UDP — game traffic
# 9777/TCP — LocalAdmin console port (optional, not exposed)
EXPOSE 7777/udp
